---
// ContactModal.astro — Modal overlay for quick contact
---

<div class="modal-overlay" id="contact-modal" style="display: none;">
  <div class="modal">
    <h2>Get in touch</h2>
    <p class="modal-sub">Send a quick note — I'll get back to you.</p>
    <div class="modal-field">
      <label>Name</label>
      <input type="text" placeholder="Your name" />
    </div>
    <div class="modal-field">
      <label>Email</label>
      <input type="email" placeholder="you@example.com" />
    </div>
    <div class="modal-field">
      <label>Message</label>
      <textarea rows="4" placeholder="What's on your mind?"></textarea>
    </div>
    <div class="modal-actions">
      <button class="btn" id="modal-cancel">Cancel</button>
      <button class="btn btn-primary" id="modal-send">Send</button>
    </div>
  </div>
</div>
