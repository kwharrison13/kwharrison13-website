---
// SearchBar.astro — universal full-text search across books + essays
// Pass context="bookshelf"|"essays"|"home" to control result ordering
interface Props {
  context?: 'bookshelf' | 'essays' | 'home';
}
const { context = 'home' } = Astro.props;
---

<div class="search-wrapper" id="search-wrapper" data-context={context}>
  <div class="search-input-row">
    <svg class="search-icon" viewBox="0 0 20 20" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="8.5" cy="8.5" r="5.5"/><line x1="12.5" y1="12.5" x2="18" y2="18"/></svg>
    <input
      type="text"
      class="search-input"
      id="search-input"
      placeholder="Search books, highlights, and essays..."
      autocomplete="off"
    />
    <kbd class="search-shortcut" id="search-shortcut">/</kbd>
  </div>
  <div class="search-dropdown" id="search-dropdown" style="display:none;"></div>
</div>

<script is:inline>
(function() {
  let index = null;
  let debounceTimer = null;
  const input = document.getElementById('search-input');
  const dropdown = document.getElementById('search-dropdown');
  const wrapper = document.getElementById('search-wrapper');
  const shortcut = document.getElementById('search-shortcut');
  const context = wrapper.dataset.context || 'home';

  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && document.activeElement !== input && !['INPUT','TEXTAREA','SELECT'].includes(document.activeElement?.tagName || '')) {
      e.preventDefault();
      input.focus();
    }
    if (e.key === 'Escape' && document.activeElement === input) {
      input.blur();
      dropdown.style.display = 'none';
    }
  });

  input.addEventListener('focus', () => { shortcut.style.display = 'none'; });
  input.addEventListener('blur', () => {
    if (!input.value) shortcut.style.display = '';
    setTimeout(() => { dropdown.style.display = 'none'; }, 200);
  });

  input.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => runSearch(input.value), 200);
  });

  async function loadIndex() {
    if (index) return index;
    const res = await fetch('/search-index.json');
    index = await res.json();
    return index;
  }

  function esc(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function highlightAll(text, query) {
    const qLower = query.toLowerCase();
    let result = '';
    let i = 0;
    const lower = text.toLowerCase();
    while (i < text.length) {
      const idx = lower.indexOf(qLower, i);
      if (idx === -1) { result += esc(text.slice(i)); break; }
      result += esc(text.slice(i, idx));
      result += '<mark>' + esc(text.slice(idx, idx + query.length)) + '</mark>';
      i = idx + query.length;
    }
    return result;
  }

  function extractSnippet(text, query, contextLen) {
    contextLen = contextLen || 90;
    const lower = text.toLowerCase();
    const qLower = query.toLowerCase();
    const idx = lower.indexOf(qLower);
    if (idx === -1) return null;
    const start = Math.max(0, idx - contextLen);
    const end = Math.min(text.length, idx + query.length + contextLen);
    let snippet = text.slice(start, end);
    if (start > 0) snippet = '\u2026' + snippet;
    if (end < text.length) snippet = snippet + '\u2026';
    return highlightAll(snippet, query);
  }

  function renderBookGroup(bookResults, query) {
    if (!bookResults.length) return '';
    let html = '<div class="sg">';
    html += '<div class="sg-label"><span class="sg-icon">▤</span> Books</div>';
    for (const b of bookResults) {
      html += '<a class="sr-item" href="/books/' + b.slug + '">';
      html += '<div class="sr-head">';
      html += '<div class="sr-title">' + highlightAll(b.title, query) + '</div>';
      html += '<div class="sr-meta">' + esc(b.author) + (b.year ? ' \u00b7 ' + esc(b.year) : '') + '</div>';
      html += '</div>';
      if (b.matchedHighlights.length) {
        html += '<div class="sr-quotes">';
        for (const h of b.matchedHighlights.slice(0, 2)) {
          html += '<div class="sr-quote">' + extractSnippet(h, query, 70) + '</div>';
        }
        if (b.matchedHighlights.length > 2) {
          html += '<div class="sr-more">+' + (b.matchedHighlights.length - 2) + ' more highlights \u2192</div>';
        }
        html += '</div>';
      }
      html += '</a>';
    }
    html += '</div>';
    return html;
  }

  function renderEssayGroup(essayResults, query) {
    if (!essayResults.length) return '';
    let html = '<div class="sg">';
    html += '<div class="sg-label"><span class="sg-icon">\u270e</span> Essays</div>';
    for (const e of essayResults) {
      html += '<a class="sr-item" href="/essays/' + e.slug + '">';
      html += '<div class="sr-head">';
      html += '<div class="sr-title">' + highlightAll(e.title, query) + '</div>';
      if (e.date) {
        try { html += '<div class="sr-meta">' + new Date(e.date).toLocaleDateString('en-US', {year:'numeric', month:'short'}) + '</div>'; } catch(_) {}
      }
      html += '</div>';
      if (e.bodySnippets.length) {
        html += '<div class="sr-quotes">';
        for (const s of e.bodySnippets.slice(0, 2)) {
          html += '<div class="sr-quote">' + s + '</div>';
        }
        html += '</div>';
      }
      html += '</a>';
    }
    html += '</div>';
    return html;
  }

  async function runSearch(query) {
    query = query.trim();
    if (query.length < 2) { dropdown.style.display = 'none'; return; }

    const data = await loadIndex();
    const qLower = query.toLowerCase();
    let bookResults = [];
    let essayResults = [];

    // Score a title against the query so exact / prefix / substring matches outrank
    // body- or author-only hits. Returns 0 when the title doesn't match at all.
    function titleScore(title) {
      const tl = title.toLowerCase();
      if (tl === qLower) return 100;        // exact title
      if (tl.startsWith(qLower)) return 80; // title starts with the query
      if (tl.includes(qLower)) return 60;   // query appears in the title
      return 0;
    }
    function timeOf(d) { const t = d ? Date.parse(d) : NaN; return isNaN(t) ? 0 : t; }

    for (const book of data.books) {
      const tScore = titleScore(book.title);
      const authorMatch = book.author.toLowerCase().includes(qLower);
      const matchedHighlights = book.highlights.filter(h => h.toLowerCase().includes(qLower));
      if (tScore || authorMatch || matchedHighlights.length > 0) {
        const score = tScore || (authorMatch ? 40 : 20);
        bookResults.push({ ...book, titleMatch: tScore > 0, authorMatch, matchedHighlights, _score: score });
      }
    }
    // Title matches first; then author; then highlight-only. Ties broken by recency.
    bookResults.sort((a, b) => b._score - a._score || timeOf(b.year) - timeOf(a.year));
    bookResults = bookResults.slice(0, 8);

    for (const essay of data.essays) {
      const tScore = titleScore(essay.title);
      const bodySnippets = [];
      if (essay.body.toLowerCase().includes(qLower)) {
        const lower = essay.body.toLowerCase();
        let searchFrom = 0;
        while (bodySnippets.length < 3) {
          const idx = lower.indexOf(qLower, searchFrom);
          if (idx === -1) break;
          const start = Math.max(0, idx - 90);
          const end = Math.min(essay.body.length, idx + qLower.length + 90);
          let snippet = essay.body.slice(start, end);
          if (start > 0) snippet = '\u2026' + snippet;
          if (end < essay.body.length) snippet = snippet + '\u2026';
          bodySnippets.push(highlightAll(snippet, query));
          searchFrom = idx + qLower.length + 150;
        }
      }
      if (tScore || bodySnippets.length > 0) {
        const score = tScore || 20; // title hits outrank body-only hits
        essayResults.push({ ...essay, titleMatch: tScore > 0, bodySnippets, _score: score });
      }
    }
    // Title matches first, then body-only; ties broken by most-recent date.
    essayResults.sort((a, b) => b._score - a._score || timeOf(b.date) - timeOf(a.date));
    essayResults = essayResults.slice(0, 8);

    if (bookResults.length === 0 && essayResults.length === 0) {
      dropdown.innerHTML = '<div class="search-empty">No results for \u201c' + esc(query) + '\u201d</div>';
      dropdown.style.display = 'block';
      return;
    }

    // Order groups based on page context
    let html = '';
    if (context === 'bookshelf') {
      html += renderBookGroup(bookResults, query);
      html += renderEssayGroup(essayResults, query);
    } else if (context === 'essays') {
      html += renderEssayGroup(essayResults, query);
      html += renderBookGroup(bookResults, query);
    } else {
      // home: essays first, then books
      html += renderEssayGroup(essayResults, query);
      html += renderBookGroup(bookResults, query);
    }

    dropdown.innerHTML = html;
    dropdown.style.display = 'block';
  }
})();
</script>

<style>
  .search-wrapper {
    position: relative;
    margin-bottom: 24px;
  }
  .search-input-row {
    display: flex;
    align-items: center;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 10px 14px;
    gap: 10px;
    transition: border-color 0.15s ease;
  }
  .search-input-row:focus-within { border-color: var(--accent); }
  .search-icon { color: var(--text-tertiary); flex-shrink: 0; }
  .search-input {
    flex: 1; border: none; background: none; outline: none;
    font-family: var(--font-body); font-size: 14px; color: var(--text); min-width: 0;
  }
  .search-input::placeholder { color: var(--text-tertiary); }
  .search-shortcut {
    background: var(--tag-bg); border: 1px solid var(--border); border-radius: 4px;
    padding: 1px 7px; font-size: 11px; font-family: var(--font-mono); color: var(--text-tertiary); flex-shrink: 0;
  }

  /* --- Dropdown --- */
  .search-dropdown {
    position: absolute; top: calc(100% + 6px); left: 0; right: 0;
    background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    max-height: 520px; overflow-y: auto; z-index: 100; padding: 6px;
  }

  /* --- Section group (Books / Essays) --- */
  .search-dropdown :global(.sg) {
    padding: 2px 0;
  }
  .search-dropdown :global(.sg + .sg) {
    border-top: 1px solid var(--border);
    margin-top: 6px;
    padding-top: 6px;
  }
  .search-dropdown :global(.sg-label) {
    font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--accent); font-weight: 700;
    padding: 8px 12px 4px; display: flex; align-items: center; gap: 6px;
  }
  .search-dropdown :global(.sg-icon) { font-size: 11px; }

  /* --- Individual result item --- */
  .search-dropdown :global(.sr-item) {
    display: block; text-decoration: none;
    padding: 8px 12px; border-radius: 8px;
    transition: background 0.1s ease;
    cursor: pointer;
  }
  .search-dropdown :global(.sr-item:hover) { background: var(--tag-bg); }
  .search-dropdown :global(.sr-item + .sr-item) {
    border-top: 1px solid color-mix(in srgb, var(--border) 50%, transparent);
  }

  /* Title + meta block */
  .search-dropdown :global(.sr-head) {
    display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap;
  }
  .search-dropdown :global(.sr-title) {
    font-size: 13.5px; font-weight: 600; color: var(--text); line-height: 1.3;
  }
  .search-dropdown :global(.sr-meta) {
    font-size: 11px; color: var(--text-tertiary); white-space: nowrap;
  }

  /* Quote / snippet block — indented under the title */
  .search-dropdown :global(.sr-quotes) {
    margin: 5px 0 2px 0; padding-left: 12px;
    border-left: 2px solid var(--border);
    display: flex; flex-direction: column; gap: 3px;
  }
  .search-dropdown :global(.sr-quote) {
    font-size: 12px; color: var(--text-secondary); line-height: 1.5;
  }
  .search-dropdown :global(.sr-more) {
    font-size: 11px; color: var(--accent); font-weight: 500; margin-top: 1px;
  }

  /* Match highlights */
  .search-dropdown :global(mark) {
    background: rgba(165, 63, 54, 0.15); color: var(--accent);
    padding: 1px 2px; border-radius: 2px; font-weight: 600;
  }

  .search-empty {
    padding: 24px 16px; text-align: center; color: var(--text-tertiary); font-size: 13px;
  }
</style>
