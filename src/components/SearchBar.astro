---
// SearchBar.astro — universal full-text search across books + essays
---

<div class="search-wrapper" id="search-wrapper">
  <div class="search-input-row">
    <span class="search-icon">⌕</span>
    <input
      type="text"
      class="search-input"
      id="search-input"
      placeholder="Search books, highlights, and essays..."
      autocomplete="off"
    />
    <span class="search-shortcut" id="search-shortcut">/</span>
  </div>
  <div class="search-dropdown" id="search-dropdown" style="display:none;"></div>
</div>

<script is:inline>
(function() {
  let index = null;
  let debounceTimer = null;
  const input = document.getElementById('search-input');
  const dropdown = document.getElementById('search-dropdown');
  const wrapper = document.getElementById('search-wrapper');
  const shortcut = document.getElementById('search-shortcut');

  // Keyboard shortcut: "/" focuses the search bar
  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && document.activeElement !== input && !['INPUT','TEXTAREA','SELECT'].includes(document.activeElement?.tagName || '')) {
      e.preventDefault();
      input.focus();
    }
    if (e.key === 'Escape' && document.activeElement === input) {
      input.blur();
      dropdown.style.display = 'none';
    }
  });

  // Hide shortcut hint when focused
  input.addEventListener('focus', () => { shortcut.style.display = 'none'; });
  input.addEventListener('blur', () => {
    if (!input.value) shortcut.style.display = '';
    setTimeout(() => { dropdown.style.display = 'none'; }, 200);
  });

  input.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => runSearch(input.value), 200);
  });

  async function loadIndex() {
    if (index) return index;
    const res = await fetch('/search-index.json');
    index = await res.json();
    return index;
  }

  function escapeHtml(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function highlightMatch(text, query) {
    const lower = text.toLowerCase();
    const qLower = query.toLowerCase();
    const idx = lower.indexOf(qLower);
    if (idx === -1) return escapeHtml(text);
    return escapeHtml(text.slice(0, idx)) +
      '<mark>' + escapeHtml(text.slice(idx, idx + query.length)) + '</mark>' +
      escapeHtml(text.slice(idx + query.length));
  }

  function extractSnippet(text, query, contextLen) {
    contextLen = contextLen || 100;
    const lower = text.toLowerCase();
    const qLower = query.toLowerCase();
    const idx = lower.indexOf(qLower);
    if (idx === -1) return null;
    const start = Math.max(0, idx - contextLen);
    const end = Math.min(text.length, idx + query.length + contextLen);
    let snippet = text.slice(start, end);
    if (start > 0) snippet = '...' + snippet;
    if (end < text.length) snippet = snippet + '...';
    return highlightMatch(snippet, query);
  }

  async function runSearch(query) {
    query = query.trim();
    if (query.length < 2) { dropdown.style.display = 'none'; return; }

    const data = await loadIndex();
    const qLower = query.toLowerCase();
    const bookResults = [];
    const essayResults = [];

    // Search books
    for (const book of data.books) {
      const titleMatch = book.title.toLowerCase().includes(qLower);
      const authorMatch = book.author.toLowerCase().includes(qLower);
      const matchedHighlights = book.highlights.filter(h => h.toLowerCase().includes(qLower));
      if (titleMatch || authorMatch || matchedHighlights.length > 0) {
        bookResults.push({ ...book, titleMatch, authorMatch, matchedHighlights });
      }
      if (bookResults.length >= 5) break;
    }

    // Search essays
    for (const essay of data.essays) {
      const titleMatch = essay.title.toLowerCase().includes(qLower);
      const bodySnippets = [];
      if (essay.body.toLowerCase().includes(qLower)) {
        // Extract up to 3 snippets
        const lower = essay.body.toLowerCase();
        let searchFrom = 0;
        while (bodySnippets.length < 3) {
          const idx = lower.indexOf(qLower, searchFrom);
          if (idx === -1) break;
          bodySnippets.push(extractSnippet(essay.body, query, 80));
          searchFrom = idx + qLower.length + 100;
        }
      }
      if (titleMatch || bodySnippets.length > 0) {
        essayResults.push({ ...essay, titleMatch, bodySnippets });
      }
      if (essayResults.length >= 5) break;
    }

    if (bookResults.length === 0 && essayResults.length === 0) {
      dropdown.innerHTML = '<div class="search-empty">No results for "' + escapeHtml(query) + '"</div>';
      dropdown.style.display = 'block';
      return;
    }

    let html = '';

    if (bookResults.length > 0) {
      html += '<div class="search-group-label">Books</div>';
      for (const b of bookResults) {
        html += '<a class="search-result" href="/books/' + b.slug + '">';
        html += '<div class="search-result-title">' + highlightMatch(b.title, query) + '</div>';
        html += '<div class="search-result-meta">' + escapeHtml(b.author) + (b.year ? ' · ' + escapeHtml(b.year) : '') + '</div>';
        const snippets = b.matchedHighlights.slice(0, 3);
        for (const h of snippets) {
          html += '<div class="search-snippet">' + extractSnippet(h, query, 80) + '</div>';
        }
        html += '</a>';
      }
    }

    if (essayResults.length > 0) {
      html += '<div class="search-group-label">Essays</div>';
      for (const e of essayResults) {
        html += '<a class="search-result" href="/essays/' + e.slug + '">';
        html += '<div class="search-result-title">' + highlightMatch(e.title, query) + '</div>';
        if (e.date) {
          try {
            html += '<div class="search-result-meta">' + new Date(e.date).toLocaleDateString('en-US', { year:'numeric', month:'short' }) + '</div>';
          } catch(_) {}
        }
        for (const s of e.bodySnippets.slice(0, 2)) {
          html += '<div class="search-snippet">' + s + '</div>';
        }
        html += '</a>';
      }
    }

    dropdown.innerHTML = html;
    dropdown.style.display = 'block';
  }
})();
</script>

<style>
  .search-wrapper {
    position: relative;
    margin-bottom: 24px;
  }
  .search-input-row {
    display: flex;
    align-items: center;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 10px 14px;
    transition: border-color 0.15s ease;
  }
  .search-input-row:focus-within {
    border-color: var(--accent);
  }
  .search-icon {
    color: var(--text-tertiary);
    font-size: 16px;
    margin-right: 10px;
    flex-shrink: 0;
  }
  .search-input {
    flex: 1;
    border: none;
    background: none;
    outline: none;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text);
    min-width: 0;
  }
  .search-input::placeholder { color: var(--text-tertiary); }
  .search-shortcut {
    background: var(--tag-bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1px 7px;
    font-size: 12px;
    font-family: var(--font-mono);
    color: var(--text-tertiary);
    flex-shrink: 0;
  }

  .search-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    max-height: 480px;
    overflow-y: auto;
    z-index: 100;
    padding: 8px;
  }
  .search-group-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
    padding: 8px 10px 4px;
    font-weight: 600;
  }
  .search-result {
    display: block;
    text-decoration: none;
    padding: 10px 10px;
    border-radius: 8px;
    transition: background 0.1s ease;
    cursor: pointer;
  }
  .search-result:hover {
    background: var(--tag-bg);
  }
  .search-result-title {
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    line-height: 1.3;
  }
  .search-result-meta {
    font-size: 11px;
    color: var(--text-tertiary);
    margin-top: 2px;
  }
  .search-snippet {
    font-size: 12px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-top: 4px;
    padding-left: 8px;
    border-left: 2px solid var(--border);
  }
  .search-snippet :global(mark) {
    background: rgba(165, 63, 54, 0.15);
    color: var(--accent);
    padding: 1px 2px;
    border-radius: 2px;
  }
  .search-empty {
    padding: 24px 16px;
    text-align: center;
    color: var(--text-tertiary);
    font-size: 13px;
  }
</style>
