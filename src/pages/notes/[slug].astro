---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getBacklinks } from '../../lib/backlinks';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((note) => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await note.render();
const published = note.data.publish === true;
const backlinks = await getBacklinks(`/notes/${note.slug}`);
const refCount = (note.data as { reference_count?: number }).reference_count ?? backlinks.length;

// Format the original source publish date. Accepts "YYYY", "YYYY-MM", or full "YYYY-MM-DD".
function fmtSourceDate(s?: string): string | null {
  if (!s) return null;
  const str = String(s).trim();
  if (/^\d{4}$/.test(str)) return str;
  if (/^\d{4}-\d{2}$/.test(str)) {
    const [y, m] = str.split('-').map(Number);
    return new Date(Date.UTC(y, m - 1, 1)).toLocaleDateString('en-US', { year: 'numeric', month: 'long', timeZone: 'UTC' });
  }
  const d = new Date(str);
  if (isNaN(d.valueOf())) return str;
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
}
const sourceDate = fmtSourceDate(note.data.source_published);
const author = note.data.author;
const sourceUrl = note.data.url;
const hasMeta = Boolean(author || sourceDate || sourceUrl);
const isToRead = note.data.type === 'books-to-read';
const kindLabel = isToRead ? 'to-read' : (note.data.format || note.data.type || 'note');
const linkLabel = isToRead ? 'Buy on Amazon ↗' : 'View original ↗';
---

<BaseLayout
  title={note.data.title}
  currentPage="notes"
  description={`Wiki note: ${note.data.title}`}
  ogType="article"
>
  <div style="margin-bottom: 8px;">
    <span class="kind-tag">{kindLabel}</span>
    {!published && <span class="private-tag">Private</span>}
  </div>

  <h1 class="page-title">{note.data.title}</h1>

  {hasMeta && (
    <div class="longform-meta">
      {author && <span class="lm-item">{author}</span>}
      {sourceDate && <span class="lm-item">{sourceDate}</span>}
      {sourceUrl && <a class="lm-item lm-link" href={sourceUrl} target="_blank" rel="noopener noreferrer">{linkLabel}</a>}
    </div>
  )}

  {published ? (
    <>
      <div class="section-divider" style="margin-top: 24px;"></div>
      <div class="prose">
        <Content />
      </div>
    </>
  ) : (
    <div class="private-note-callout">
      <div class="private-note-lock">🔒</div>
      <div class="private-note-body">
        <strong>This is a private wiki note.</strong>
        <p>The full content lives in Kyle's personal knowledge base and isn't published to the public site. It's referenced from {refCount} other page{refCount === 1 ? '' : 's'} — those references are listed below.</p>
      </div>
    </div>
  )}

  {backlinks.length > 0 && (
    <section class="backlinks">
      <h2 class="backlinks-title">Referenced in</h2>
      <ul class="backlinks-list">
        {backlinks.map((bl) => (
          <li>
            <a href={bl.url}>{bl.title}</a>
            <span class="backlinks-kind">{bl.kind === 'books' ? 'book' : bl.kind === 'essays' ? 'essay' : 'note'}</span>
          </li>
        ))}
      </ul>
    </section>
  )}
</BaseLayout>

<style>
  .kind-tag {
    background: var(--tag-bg);
    color: var(--text-secondary);
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }
  .private-tag {
    background: transparent;
    color: var(--text-tertiary);
    font-size: 11px;
    padding: 2px 6px;
    border: 1px solid var(--border);
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    margin-left: 6px;
  }

  .longform-meta {
    margin-top: 10px;
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .lm-item:not(:first-child)::before {
    content: "·";
    margin: 0 8px;
    color: var(--text-tertiary);
  }
  .lm-link {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--accent) 30%, transparent);
    text-underline-offset: 2px;
    white-space: nowrap;
  }
  .lm-link:hover { text-decoration-color: var(--accent); }

  .private-note-callout {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--text-tertiary);
    border-radius: 8px;
    padding: 18px 22px;
    margin-top: 28px;
    max-width: 640px;
  }
  .private-note-lock {
    font-size: 24px;
    line-height: 1;
    flex: 0 0 auto;
    margin-top: 2px;
  }
  .private-note-body { font-size: 14.5px; line-height: 1.6; color: var(--text-secondary); }
  .private-note-body strong { color: var(--text); }
  .private-note-body p { margin: 8px 0 0; }

  .backlinks {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    max-width: 640px;
  }
  .backlinks-title {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 600;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 14px;
  }
  .backlinks-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 6px;
  }
  .backlinks-list li {
    display: flex;
    align-items: baseline;
    gap: 10px;
    font-size: 14.5px;
  }
  .backlinks-list a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--accent) 30%, transparent);
    text-underline-offset: 2px;
  }
  .backlinks-list a:hover { text-decoration-color: var(--accent); }
  .backlinks-kind {
    font-size: 11px;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* Reuse prose styles consistent with essays */
  .prose :global(p) { margin-bottom: 16px; }
  .prose :global(a) { color: var(--accent); }
</style>
