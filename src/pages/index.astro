---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" currentPage="home">
  <h1 class="page-title">
    Mapping the <em>architecture</em> of compounding human potential.
  </h1>
  <p class="page-subtitle">
    General Partner @ Contrary. Founder @ Contrary Research. Father of 4.
    Member of The Church of Jesus Christ of Latter-Day Saints.
  </p>

  <div class="epigraph-block">
    <div class="epigraph">
      <p>"I write because I don't know what I think until I read what I say."</p>
      <cite>Flannery O'Connor</cite>
    </div>
    <div class="epigraph">
      <p>"Write something worth reading or do something worth writing."</p>
      <cite>Benjamin Franklin</cite>
    </div>
    <div class="epigraph">
      <p>"If we write, it is more likely that we understand what we read, remember what we learn and that our thoughts make sense."</p>
      <cite>Sönke Ahrens</cite>
    </div>
  </div>

  <div class="info-grid">
    <span class="info-label">Focus</span>
    <span class="info-value">AI disruption of vertical software — which moats survive, and which don't.</span>
    <span class="info-label">Background</span>
    <span class="info-value">Index Ventures · Coatue · TCV · Former Founder</span>
  </div>

  <div style="margin-top: 40px;">
    <h2 class="section-heading">Updates <span class="dash">— recent</span></h2>
    <div class="section-divider"></div>

    <div class="update-card">
      <div class="update-icon">📝</div>
      <div class="update-content">
        <div class="update-title">Hijacking The Huckster's Hypebook</div>
        <div class="update-excerpt">An analytical essay on the repeatable fundraising playbook used by charismatic founders — from outright fraud to "righteous hucksters" who delivered real results.</div>
        <div class="update-meta"><span class="update-tag">Investing 101</span> In progress</div>
      </div>
    </div>

    <div class="update-card">
      <div class="update-icon">🔬</div>
      <div class="update-content">
        <div class="update-title">Contrary Research: CR100 Framework</div>
        <div class="update-excerpt">Building a systematic coverage framework focused on 100 key companies across the Contrary portfolio and pipeline.</div>
        <div class="update-meta"><span class="update-tag">Contrary</span> Ongoing</div>
      </div>
    </div>

    <div class="update-card">
      <div class="update-icon">🤖</div>
      <div class="update-content">
        <div class="update-title">AI-Proof SaaS Scoring System</div>
        <div class="update-excerpt">Applying a framework across 74 SaaS companies to identify defensible businesses at distressed valuations in an AI-disrupted landscape.</div>
        <div class="update-meta"><span class="update-tag">Research</span> 2024–25</div>
      </div>
    </div>
  </div>
</BaseLayout>
