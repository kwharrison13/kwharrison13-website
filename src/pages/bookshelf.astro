---
import BaseLayout from '../layouts/BaseLayout.astro';

import booksData from '../data/books.json';
---

<BaseLayout title="Bookshelf" currentPage="bookshelf">
  <h1 class="page-title">Bookshelf</h1>
  <p class="page-subtitle">
    This page is an archive for my <a href="https://investing101.substack.com/" target="_blank" rel="noreferrer" style="color: var(--accent); text-decoration: underline; font-weight: 500;">"quake books"</a> that have had the most profound impact on me.
  </p>
  <div class="section-divider"></div>

  {booksData.map((book) => (
    <div class="book-item" data-isbn={book.isbn} data-title={book.title}>
      <img
        class="book-cover-img"
        src=""
        alt={book.title}
        loading="lazy"
      />
      <div>
        <div class="book-title">{book.title}</div>
        <div class="book-author">{book.author}</div>
      </div>
    </div>
  ))}

  <script is:inline>
    document.querySelectorAll('.book-item[data-isbn]').forEach(async (el) => {
      const isbn = el.dataset.isbn;
      const title = el.dataset.title;
      const img = el.querySelector('.book-cover-img');
      const query = isbn ? `isbn:${isbn}` : encodeURIComponent(title);
      try {
        const res = await fetch(`https://www.googleapis.com/books/v1/volumes?q=${query}&maxResults=1`);
        const data = await res.json();
        if (data.items && data.items[0]?.volumeInfo?.imageLinks?.thumbnail) {
          img.src = data.items[0].volumeInfo.imageLinks.thumbnail.replace('http://', 'https://');
        }
      } catch {}
    });
  </script>
</BaseLayout>
