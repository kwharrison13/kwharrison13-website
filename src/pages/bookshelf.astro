---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBar from '../components/SearchBar.astro';
import booksData from '../data/books.json';
import antilibrary from '../data/antilibrary.json';
import { bookSlug } from '../lib/bookSlug';

const quakeBooks = booksData.quake_books;
const library = booksData.library as Record<string, any[]>;
// Sort numeric years descending, "pre-2016" goes last
const yearKeys = Object.keys(library).sort((a, b) => {
  const na = Number(a), nb = Number(b);
  if (isNaN(na) && isNaN(nb)) return 0;
  if (isNaN(na)) return 1;
  if (isNaN(nb)) return -1;
  return nb - na;
});

const allTags: Record<string, { title: string; author: string; year: string }[]> = {};
for (const [year, books] of Object.entries(library)) {
  for (const book of books) {
    if (book.tags) {
      for (const tag of book.tags) {
        if (!allTags[tag]) allTags[tag] = [];
        allTags[tag].push({ title: book.title, author: book.author, year });
      }
    }
  }
}
const sortedTags = Object.entries(allTags).sort((a, b) => b[1].length - a[1].length);
const totalBooks = Object.values(library).reduce((sum, books) => sum + books.length, 0);
const yearsWithBooks = yearKeys.filter(y => library[y].length > 0);
---

<BaseLayout title="Bookshelf" currentPage="bookshelf" description="Kyle Harrison's reading list — books that have shaped his thinking on venture capital, technology, history, and human potential.">
  <h1 class="page-title">Bookshelf</h1>
  <p class="page-subtitle">
    {totalBooks} books across {yearsWithBooks.length} years. The <span style="color: var(--accent); font-weight: 600;">quake books</span> are the ones that changed how I think.
  </p>

  <blockquote class="bookshelf-epigraph">
    <p>In my whole life, I have known no wise people (over a broad subject matter area) who didn't read all the time—none, zero. You'd be amazed at how much Warren reads—and at how much I read. My children laugh at me. They think I'm a book with a couple of legs sticking out.</p>
    <footer>— Charlie Munger</footer>
  </blockquote>

  <SearchBar context="bookshelf" />

  <div class="bookshelf-tabs">
    <button class="bookshelf-tab active" data-view="quake">Quake Books</button>
    <button class="bookshelf-tab" data-view="library">Full Library</button>
    <button class="bookshelf-tab" data-view="topics">By Topic</button>
    <button class="bookshelf-tab" data-view="antilibrary">Anti-Library</button>
  </div>

  <div class="bookshelf-view" id="view-quake">
    <p class="view-intro">
      These are the books that fundamentally shifted my worldview — the ones I return to and reference constantly. Not the best books I've read, but the ones that left the deepest mark.
    </p>
    <div class="quake-list">
      {quakeBooks.map((book: any, i: number) => (
        <a href={`/books/${bookSlug(book.title)}`} class="quake-item quake-item-link">
          {book.cover ? (
            <img class="quake-cover" src={book.cover} alt={book.title} loading="lazy" />
          ) : (
            <div class="quake-cover-placeholder" style={`background: linear-gradient(135deg, hsl(${355 + i * 25}, 55%, 38%) 0%, hsl(${355 + i * 25}, 45%, 25%) 100%);`}></div>
          )}
          <div class="quake-info">
            <div class="quake-title">{book.title}</div>
            <div class="quake-author">{book.author}</div>
          </div>
          <div class="quake-diamond">◆</div>
        </a>
      ))}
    </div>
  </div>

  <div class="bookshelf-view" id="view-library" style="display: none;">
    <div class="year-pills">
      {yearKeys.map((year: string, i: number) => (
        <button class={`year-pill ${i === 0 ? 'active' : ''}`} data-year={year}>
          {year} <span class="year-count">({library[year].length})</span>
        </button>
      ))}
    </div>

    {yearKeys.map((year: string, yi: number) => {
      const books = library[year];
      const quakeCount = books.filter((b: any) => b.quake).length;
      const avgRating = books.length > 0 ? (books.reduce((sum: number, b: any) => sum + (b.rating || 0), 0) / books.length).toFixed(1) : '—';
      const yearTags = [...new Set(books.flatMap((b: any) => b.tags || []))].sort() as string[];
      return (
        <div class={`year-content ${yi === 0 ? 'active' : ''}`} data-year-content={year}>
          <div class="year-stats">
            <div class="stat">
              <div class="stat-number">{books.length}</div>
              <div class="stat-label">Books</div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
              <div class="stat-number" style="color: var(--accent);">{quakeCount}</div>
              <div class="stat-label">Quake</div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
              <div class="stat-number">{avgRating}</div>
              <div class="stat-label">Avg Rating</div>
            </div>
          </div>

          {yearTags.length > 0 && (
            <div class="year-tag-filter">
              <button class="tag-pill active" data-filter-tag="all">All</button>
              {yearTags.map((tag: string) => (
                <button class="tag-pill" data-filter-tag={tag}>{tag}</button>
              ))}
            </div>
          )}

          <div class="library-list">
            {books.map((book: any) => (
              <a href={`/books/${bookSlug(book.title)}`} class="library-item library-item-link" data-tags={JSON.stringify(book.tags || [])}>
                <div class="rating-dots">
                  {[1,2,3,4,5].map((star: number) => (
                    <div class={`rating-dot ${star <= (book.rating || 0) ? 'filled' : ''}`}></div>
                  ))}
                </div>
                <div class="library-info">
                  <div class="library-title-row">
                    <span class="library-title">{book.title}</span>
                    {book.quake && <span class="quake-badge">◆ QUAKE</span>}
                  </div>
                  <div class="library-author">{book.author}</div>
                </div>
                <div class="library-tags">
                  {(book.tags || []).slice(0, 2).map((tag: string) => (
                    <span class="library-tag">{tag}</span>
                  ))}
                </div>
              </a>
            ))}
          </div>
        </div>
      );
    })}
  </div>

  <div class="bookshelf-view" id="view-topics" style="display: none;">
    <p class="view-intro">
      Every book tagged by topic — this is what feeds into the <a href="/portfolio" style="color: var(--accent); text-decoration: underline;">Portfolio Ideas</a> pages.
    </p>
    <div class="topics-list">
      {sortedTags.map(([tag, books]) => (
        <div class="topic-group">
          <div class="topic-header">
            <a href={`/portfolio/${tag}`} class="topic-name">{tag}</a>
            <span class="topic-count">({books.length})</span>
            <div class="topic-line"></div>
          </div>
          <div class="topic-books">
            {books.map((book) => (
              <a href={`/books/${bookSlug(book.title)}`} class="topic-book-chip topic-book-chip-link">
                <div class="topic-book-title">{book.title}</div>
                <div class="topic-book-author">{book.author}</div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="bookshelf-view" id="view-antilibrary" style="display: none;">
    <blockquote class="antilib-quote">
      <p>A private library is not an ego-boosting appendage but a research tool. Read books are far less valuable than unread ones. The library should contain as much of what you do not know as your financial means, mortgage rates, and the currently tight real-estate market allow you to put there. You will accumulate more knowledge and more books as you grow older, and the growing number of unread books on the shelves will look at you menacingly. Indeed, the more you know, the larger the rows of unread books. Let us call this collection of unread books an antilibrary.</p>
      <footer>— Umberto Eco (<a href="/books/the-black-swan">Black Swan</a>)</footer>
    </blockquote>

    <div class="antilib-toolbar">
      <input type="text" id="antilib-search" class="antilib-search" placeholder="Search the anti-library by title or author…" autocomplete="off" />
      <span class="antilib-count">{antilibrary.length} unread</span>
    </div>

    {antilibrary.length === 0 ? (
      <p class="view-intro">Nothing here yet. Tag an inbox source <code>#books-to-read</code> and run <code>/ingest</code> to populate the anti-library.</p>
    ) : (
      <div class="antilib-table" role="table">
        <div class="antilib-row antilib-head" role="row">
          <span role="columnheader">Title</span>
          <span role="columnheader">Author</span>
          <span role="columnheader">Published</span>
          <span role="columnheader">Pages</span>
          <span role="columnheader">Connections</span>
          <span role="columnheader">Where I saw it</span>
          <span role="columnheader">Buy</span>
        </div>
        {antilibrary.map((b: any) => (
          <div class="antilib-row" role="row" data-search={`${b.title} ${b.full_title} ${b.author}`.toLowerCase()}>
            <span class="al-title" role="cell"><a href={`/notes/${b.slug}`}>{b.full_title || b.title}</a></span>
            <span class="al-author" role="cell" data-label="Author">{b.author || '—'}</span>
            <span class="al-pub" role="cell" data-label="Published">{b.published || '—'}</span>
            <span class="al-pages" role="cell" data-label="Pages">{b.pages ?? '—'}</span>
            <span class="al-conn" role="cell" data-label="Connections">
              {b.connections.length === 0 ? <span class="al-muted">—</span> : b.connections.map((c: any) => (
                <a class="al-chip" href={c.url}>{c.title}</a>
              ))}
            </span>
            <span class="al-seen" role="cell" data-label="Where I saw it">{b.where_seen.length ? b.where_seen.join(' · ') : <span class="al-muted">—</span>}</span>
            <span class="al-buy" role="cell" data-label="Buy">
              {b.amazon_url ? <a href={b.amazon_url} target="_blank" rel="noopener noreferrer">Amazon ↗</a> : <span class="al-muted">—</span>}
            </span>
          </div>
        ))}
        <div class="antilib-empty" id="antilib-empty" style="display: none;">No unread books match that search.</div>
      </div>
    )}
  </div>

  <script is:inline>
    document.querySelectorAll('.bookshelf-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.bookshelf-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        document.querySelectorAll('.bookshelf-view').forEach(v => v.style.display = 'none');
        document.getElementById('view-' + tab.dataset.view).style.display = 'block';
      });
    });
    document.querySelectorAll('.year-pill').forEach(pill => {
      pill.addEventListener('click', () => {
        document.querySelectorAll('.year-pill').forEach(p => p.classList.remove('active'));
        pill.classList.add('active');
        document.querySelectorAll('.year-content').forEach(c => c.classList.remove('active'));
        document.querySelector('[data-year-content="' + pill.dataset.year + '"]')?.classList.add('active');
      });
    });
    document.querySelectorAll('.tag-pill').forEach(pill => {
      pill.addEventListener('click', () => {
        const parent = pill.closest('.year-content');
        parent.querySelectorAll('.tag-pill').forEach(p => p.classList.remove('active'));
        pill.classList.add('active');
        const tag = pill.dataset.filterTag;
        parent.querySelectorAll('.library-item').forEach(item => {
          if (tag === 'all') { item.style.display = ''; }
          else {
            const tags = JSON.parse(item.dataset.tags || '[]');
            item.style.display = tags.includes(tag) ? '' : 'none';
          }
        });
      });
    });
    const antilibSearch = document.getElementById('antilib-search');
    if (antilibSearch) {
      antilibSearch.addEventListener('input', () => {
        const q = antilibSearch.value.trim().toLowerCase();
        let visible = 0;
        document.querySelectorAll('.antilib-row:not(.antilib-head)').forEach(row => {
          const hay = row.dataset.search || '';
          const show = q === '' || hay.includes(q);
          row.style.display = show ? '' : 'none';
          if (show) visible++;
        });
        const empty = document.getElementById('antilib-empty');
        if (empty) empty.style.display = visible === 0 ? '' : 'none';
      });
    }
  </script>
</BaseLayout>

<style>
  .bookshelf-epigraph { margin: 0 0 24px; padding: 0 0 0 18px; border-left: 3px solid var(--accent); max-width: 680px; }
  .bookshelf-epigraph p { font-family: var(--font-display); font-size: 15.5px; line-height: 1.7; color: var(--text-secondary); font-style: italic; margin: 0; }
  .bookshelf-epigraph footer { margin-top: 10px; font-size: 13px; color: var(--text-tertiary); font-style: normal; }

  .bookshelf-tabs { display: flex; gap: 0; border-bottom: 1px solid var(--border); margin-bottom: 24px; }
  .bookshelf-tab { background: none; border: none; color: var(--text-tertiary); font-family: var(--font-body); font-size: 13px; font-weight: 600; padding: 12px 18px; cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.15s ease; }
  .bookshelf-tab:hover { color: var(--text-secondary); }
  .bookshelf-tab.active { color: var(--text); border-bottom-color: var(--accent); }
  .view-intro { color: var(--text-secondary); font-size: 14px; line-height: 1.7; margin-bottom: 24px; max-width: 560px; }

  .quake-list { display: flex; flex-direction: column; gap: 10px; }
  .quake-item { display: flex; align-items: center; gap: 16px; padding: 14px 16px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; transition: border-color 0.15s ease; }
  .quake-item:hover { border-color: var(--accent); }
  .quake-item-link { text-decoration: none; color: inherit; cursor: pointer; }
  .quake-cover { width: 48px; height: 64px; object-fit: cover; border-radius: 4px; flex-shrink: 0; }
  .quake-cover-placeholder { width: 48px; height: 64px; border-radius: 4px; flex-shrink: 0; }
  .quake-info { flex: 1; }
  .quake-title { font-family: var(--font-display); font-size: 15px; font-weight: 500; color: var(--text); line-height: 1.3; }
  .quake-author { font-size: 12.5px; color: var(--text-tertiary); margin-top: 2px; }
  .quake-diamond { color: var(--accent); font-size: 16px; flex-shrink: 0; }

  .year-pills { display: flex; gap: 6px; margin-bottom: 20px; flex-wrap: wrap; }
  .year-pill { background: var(--tag-bg); border: 1px solid var(--border); color: var(--text-secondary); font-family: var(--font-body); font-size: 13px; font-weight: 600; padding: 8px 16px; border-radius: 8px; cursor: pointer; transition: all 0.15s ease; }
  .year-pill:hover { border-color: var(--text-tertiary); }
  .year-pill.active { background: var(--accent); border-color: var(--accent); color: white; }
  .year-count { opacity: 0.6; font-size: 11px; margin-left: 2px; }

  .year-content { display: none; }
  .year-content.active { display: block; }

  .year-stats { display: flex; gap: 16px; padding: 12px 16px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; margin-bottom: 16px; }
  .stat-number { font-size: 20px; font-weight: 700; color: var(--text); }
  .stat-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-tertiary); }
  .stat-divider { width: 1px; background: var(--border); }

  .year-tag-filter { display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 16px; }
  .tag-pill { background: transparent; border: 1px solid var(--border); color: var(--text-tertiary); font-family: var(--font-body); font-size: 11px; padding: 4px 8px; border-radius: 4px; cursor: pointer; transition: all 0.15s ease; }
  .tag-pill:hover { color: var(--text-secondary); }
  .tag-pill.active { background: var(--tag-bg); color: var(--text); border-color: var(--text-tertiary); }

  .library-list { display: flex; flex-direction: column; gap: 4px; }
  .library-item { display: flex; align-items: center; gap: 14px; padding: 10px 14px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; transition: border-color 0.15s ease; }
  .library-item:hover { border-color: var(--text-tertiary); }
  .library-item-link { text-decoration: none; color: inherit; cursor: pointer; }
  .library-item-link:hover { border-color: var(--accent); }
  .rating-dots { display: flex; gap: 3px; flex-shrink: 0; width: 52px; }
  .rating-dot { width: 7px; height: 7px; border-radius: 2px; background: var(--border); }
  .rating-dot.filled { background: var(--accent); }
  .library-info { flex: 1; min-width: 0; }
  .library-title-row { display: flex; align-items: center; gap: 8px; }
  .library-title { font-size: 13px; font-weight: 500; color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .quake-badge { color: var(--accent); font-size: 10px; font-weight: 700; flex-shrink: 0; }
  .library-author { font-size: 11px; color: var(--text-tertiary); margin-top: 1px; }
  .library-tags { display: flex; gap: 4px; flex-shrink: 0; }
  .library-tag { font-size: 9px; color: var(--text-tertiary); background: var(--tag-bg); border: 1px solid var(--border); padding: 2px 6px; border-radius: 3px; }

  .topics-list { display: flex; flex-direction: column; gap: 20px; }
  .topic-header { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
  .topic-name { font-size: 14px; font-weight: 600; color: var(--accent); text-decoration: none; }
  .topic-name:hover { text-decoration: underline; }
  .topic-count { font-size: 11px; color: var(--text-tertiary); }
  .topic-line { flex: 1; height: 1px; background: var(--border); }
  .topic-books { display: flex; gap: 8px; flex-wrap: wrap; }
  .topic-book-chip { background: var(--bg-card); border: 1px solid var(--border); border-radius: 6px; padding: 8px 12px; max-width: 200px; transition: border-color 0.15s ease; }
  .topic-book-chip-link { text-decoration: none; color: inherit; cursor: pointer; display: block; }
  .topic-book-chip-link:hover { border-color: var(--accent); }
  .topic-book-title { font-size: 12px; font-weight: 500; color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .topic-book-author { font-size: 10px; color: var(--text-tertiary); margin-top: 2px; }

  @media (max-width: 640px) { .library-tags { display: none; } .year-stats { gap: 12px; } }

  /* ── Anti-Library ── */
  .antilib-quote { margin: 0 0 28px; padding: 18px 22px; background: var(--bg-card); border: 1px solid var(--border); border-left: 3px solid var(--accent); border-radius: 8px; max-width: 760px; }
  .antilib-quote p { font-family: var(--font-display); font-size: 15px; line-height: 1.75; color: var(--text-secondary); font-style: italic; margin: 0; }
  .antilib-quote footer { margin-top: 12px; font-size: 13px; color: var(--text-tertiary); font-style: normal; }
  .antilib-quote footer a { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; }

  .antilib-toolbar { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
  .antilib-search { flex: 1; max-width: 420px; background: var(--bg-card); border: 1px solid var(--border); color: var(--text); font-family: var(--font-body); font-size: 13px; padding: 9px 14px; border-radius: 8px; }
  .antilib-search:focus { outline: none; border-color: var(--accent); }
  .antilib-search::placeholder { color: var(--text-tertiary); }
  .antilib-count { font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-tertiary); white-space: nowrap; }

  .antilib-table { display: flex; flex-direction: column; border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
  .antilib-row { display: grid; grid-template-columns: minmax(150px, 2fr) 0.9fr 74px 58px 1.7fr 1.8fr 74px; align-items: stretch; border-bottom: 1px solid var(--border); }
  .antilib-row > span { min-width: 0; overflow: hidden; padding: 12px 12px; border-right: 1px solid var(--border); }
  .antilib-row > span:last-child { border-right: none; }
  .antilib-row:last-child { border-bottom: none; }
  .antilib-row:not(.antilib-head):hover { background: var(--bg-card); }
  .antilib-head { background: var(--bg-card); font-size: 10px; text-transform: uppercase; letter-spacing: 0.07em; font-weight: 700; color: var(--text-tertiary); position: sticky; top: 0; }
  .al-title a { font-family: var(--font-display); font-size: 14px; font-weight: 500; color: var(--text); text-decoration: none; line-height: 1.35; }
  .al-title a:hover { color: var(--accent); }
  .al-author, .al-pub, .al-pages, .al-seen { font-size: 12.5px; color: var(--text-secondary); }
  .al-pages { font-variant-numeric: tabular-nums; }
  .al-seen { font-size: 11.5px; color: var(--text-tertiary); line-height: 1.5; }
  .al-conn { display: flex; flex-wrap: wrap; align-content: start; gap: 5px; }
  .al-chip { font-size: 10.5px; color: var(--text-secondary); background: var(--tag-bg); border: 1px solid var(--border); padding: 2px 7px; border-radius: 4px; text-decoration: none; max-width: 100%; min-width: 0; white-space: normal; overflow-wrap: anywhere; word-break: break-word; }
  .al-chip:hover { border-color: var(--accent); color: var(--accent); }
  .al-buy a { font-size: 11.5px; color: var(--accent); text-decoration: none; white-space: nowrap; }
  .al-buy a:hover { text-decoration: underline; }
  .al-muted { color: var(--text-tertiary); }
  .antilib-empty { padding: 24px 16px; text-align: center; font-size: 13px; color: var(--text-tertiary); }

  @media (max-width: 760px) {
    .antilib-head { display: none; }
    .antilib-row { grid-template-columns: 1fr; gap: 6px; padding: 14px 16px; }
    .antilib-row > span { padding: 0; border-right: none; overflow: visible; }
    .antilib-row:not(.antilib-head) span[data-label]::before { content: attr(data-label) ": "; font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-tertiary); font-weight: 600; }
    .antilib-row:not(.antilib-head):hover { background: transparent; }
  }
</style>
