---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getBacklinks } from '../../lib/backlinks';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map(essay => ({
    params: { slug: essay.slug },
    props: { essay },
  }));
}

const { essay } = Astro.props;
const { Content } = await essay.render();
const backlinks = await getBacklinks(`/essays/${essay.slug}`);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": essay.data.title,
  "datePublished": essay.data.date,
  "author": {
    "@type": "Person",
    "name": "Kyle Harrison",
    "url": "https://kwharrison13.com/about"
  },
  "publisher": {
    "@type": "Person",
    "name": "Kyle Harrison"
  },
  "description": essay.data.excerpt || "",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://kwharrison13.com/essays/${essay.slug}`
  }
};
---

<BaseLayout
  title={essay.data.title}
  currentPage="essays"
  description={essay.data.excerpt || `Essay by Kyle Harrison: ${essay.data.title}`}
  ogType="article"
  article={{ publishedTime: essay.data.date, tags: essay.data.tags }}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div style="margin-bottom: 8px;">
    <span class="update-tag">{essay.data.tags?.[0]}</span>
    <span style="font-size: 12px; color: var(--text-tertiary); margin-left: 8px;">{new Date(essay.data.date).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</span>
  </div>
  <h1 class="page-title">{essay.data.title}</h1>
  {essay.data.substack_url && (
    <div class="originally-published">
      Originally published on <a href={essay.data.substack_url} target="_blank" rel="noopener noreferrer">Investing 101</a>
    </div>
  )}
  <div class="section-divider" style="margin-top: 24px;"></div>
  <div class="prose">
    <Content />
  </div>

  {backlinks.length > 0 && (
    <section class="backlinks">
      <h2 class="backlinks-title">Referenced in</h2>
      <ul class="backlinks-list">
        {backlinks.map((bl) => (
          <li>
            <a href={bl.url}>{bl.title}</a>
            <span class="backlinks-kind">{bl.kind === 'books' ? 'book' : bl.kind === 'essays' ? 'essay' : 'note'}</span>
          </li>
        ))}
      </ul>
    </section>
  )}
</BaseLayout>

<style>
  .originally-published {
    font-size: 12.5px;
    color: var(--text-tertiary);
    margin-top: 6px;
  }
  .originally-published a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .originally-published a:hover { text-decoration-color: var(--accent); }

  /* Wiki Connections callout — :global() because the aside is rendered
     by markdown <Content />, which scoped class hashing doesn't reach. */
  .prose :global(.wiki-connections) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 8px;
    padding: 14px 18px 16px;
    margin: 0 0 32px;
  }
  .prose :global(.wiki-connections-label) {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    font-weight: 600;
    color: var(--text-tertiary);
    margin-bottom: 10px;
  }
  .prose :global(.wiki-connections-row) {
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--text-secondary);
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
  }
  .prose :global(.wiki-connections-row + .wiki-connections-row) {
    margin-top: 6px;
  }
  .prose :global(.wiki-connections-kind) {
    flex: 0 0 auto;
    font-weight: 600;
    color: var(--text);
    font-size: 13px;
    min-width: 48px;
  }
  .prose :global(.wiki-connections-items) {
    flex: 1 1 auto;
    min-width: 0;
  }
  .prose :global(.wiki-connections a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--accent) 30%, transparent);
    text-underline-offset: 2px;
  }
  .prose :global(.wiki-connections a:hover) {
    text-decoration-color: var(--accent);
  }

  .backlinks {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    max-width: 640px;
  }
  .backlinks-title {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 600;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 14px;
  }
  .backlinks-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 6px; }
  .backlinks-list li { display: flex; align-items: baseline; gap: 10px; font-size: 14.5px; }
  .backlinks-list a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--accent) 30%, transparent);
    text-underline-offset: 2px;
  }
  .backlinks-list a:hover { text-decoration-color: var(--accent); }
  .backlinks-kind {
    font-size: 11px;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
</style>
