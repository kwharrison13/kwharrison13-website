<style>
  .pod-grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .pod-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 12px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-card);
    text-decoration: none;
    color: var(--text);
    transition: all 0.15s ease;
    cursor: pointer;
  }
  .pod-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
    padding-left: 16px;
  }
  .pod-thumb {
    width: 120px;
    height: 68px;
    object-fit: cover;
    border-radius: 6px;
    flex-shrink: 0;
  }
  .pod-icon-wrap {
    width: 120px;
    height: 68px;
    border-radius: 6px;
    background: var(--pod-gradient, linear-gradient(135deg, hsl(220, 45%, 35%) 0%, hsl(220, 35%, 22%) 100%));
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
  }
  .pod-icon-initials {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.85);
    letter-spacing: -0.02em;
    text-align: center;
    line-height: 1.1;
  }
  .pod-icon-emoji {
    font-size: 28px;
  }
  .pod-info {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }
  .pod-source {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent);
  }
  .pod-title {
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (max-width: 600px) {
    .pod-thumb,
    .pod-icon-wrap {
      width: 80px;
      height: 45px;
    }
    .pod-icon-emoji {
      font-size: 20px;
    }
    .pod-title {
      font-size: 13px;
    }
  }
</style>
