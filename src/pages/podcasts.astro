---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Podcasts are wiki-native (wiki/podcasts/*.md → synced into the `podcasts`
// collection). Each card links to a rich internal page at /podcasts/<slug>.
const all = (await getCollection('podcasts'))
  .filter((p) => p.data.publish !== false)
  .sort((a, b) => {
    const da = new Date(a.data.episode_date || 0).valueOf();
    const db = new Date(b.data.episode_date || 0).valueOf();
    return (isNaN(db) ? 0 : db) - (isNaN(da) ? 0 : da);
  });

const sections = [
  { key: 'appearance', heading: 'My Podcast Appearances' },
  { key: 'hosted', heading: 'My Podcasts' },
  { key: 'media', heading: 'Other Media' },
];

// Deterministic gradient hue from a string (for cards without a thumbnail).
function hue(s: string): number {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) % 360;
  return h;
}
function initials(s?: string): string {
  if (!s) return '◉';
  const words = s.replace(/[^A-Za-z0-9 ]/g, '').split(/\s+/).filter(Boolean);
  if (words.length === 1) return words[0].slice(0, 3).toUpperCase();
  return words.slice(0, 3).map((w) => w[0]).join('').toUpperCase();
}

const sourceName: Record<string, string> = {
  youtube: 'YouTube', apple: 'Apple Podcasts', spotify: 'Spotify', web: '',
};

function card(p: (typeof all)[number]) {
  const d = p.data;
  const thumb = d.image || (d.youtube_id ? `https://img.youtube.com/vi/${d.youtube_id}/mqdefault.jpg` : null);
  const source = sourceName[d.source || ''] || d.show || '';
  return { d, slug: p.slug, thumb, source };
}
---

<BaseLayout title="Podcasts" currentPage="podcasts" description="Podcast appearances, hosted conversations, and media coverage featuring Kyle Harrison on venture capital, AI, and startups.">
  <h1 class="page-title">Podcasts</h1>
  <p class="page-subtitle">Conversations, appearances, and media coverage — each with the full episode, notes, and connections.</p>

  <div class="section-divider"></div>

  {sections.map((section) => {
    const items = all.filter((p) => (p.data.category || 'appearance') === section.key).map(card);
    if (items.length === 0) return null;
    return (
      <>
        <h2 class="section-heading">{section.heading}</h2>
        <div class="section-divider"></div>
        <div class="pod-grid">
          {items.map(({ d, slug, thumb, source }) => (
            <a class="pod-card" href={`/podcasts/${slug}`}>
              {thumb ? (
                <img class="pod-thumb" src={thumb} alt={d.title} loading="lazy" />
              ) : d.format === 'press' ? (
                <div class="pod-icon-wrap"><span class="pod-icon-emoji">📰</span></div>
              ) : (
                <div class="pod-icon-wrap" style={`--pod-gradient: linear-gradient(135deg, hsl(${hue(d.show || d.title)}, 50%, 35%) 0%, hsl(${hue(d.show || d.title)}, 40%, 22%) 100%);`}>
                  <span class="pod-icon-initials">{initials(d.show)}</span>
                </div>
              )}
              <div class="pod-info">
                {source && <span class="pod-source">{source}</span>}
                <span class="pod-title">{d.title}</span>
              </div>
            </a>
          ))}
        </div>
        <div class="section-divider" style="margin-top: 40px;"></div>
      </>
    );
  })}
</BaseLayout>

<style>
  .pod-grid { display: flex; flex-direction: column; gap: 8px; }
  .pod-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 12px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-card);
    text-decoration: none;
    color: var(--text);
    transition: all 0.15s ease;
    cursor: pointer;
  }
  .pod-card:hover { border-color: var(--accent); box-shadow: var(--shadow-md); padding-left: 16px; }
  .pod-thumb {
    width: 120px; height: 68px; object-fit: cover; border-radius: 6px; flex-shrink: 0;
  }
  .pod-icon-wrap {
    width: 120px; height: 68px; border-radius: 6px;
    background: var(--pod-gradient, linear-gradient(135deg, hsl(220, 45%, 35%) 0%, hsl(220, 35%, 22%) 100%));
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    position: relative; overflow: hidden;
  }
  .pod-icon-initials {
    font-family: var(--font-display); font-size: 20px; font-weight: 600;
    color: rgba(255, 255, 255, 0.85); letter-spacing: -0.02em; text-align: center; line-height: 1.1;
  }
  .pod-icon-emoji { font-size: 28px; }
  .pod-info { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
  .pod-source {
    font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--accent);
  }
  .pod-title {
    font-size: 14px; font-weight: 500; color: var(--text); line-height: 1.35;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  @media (max-width: 600px) {
    .pod-thumb, .pod-icon-wrap { width: 80px; height: 45px; }
    .pod-icon-emoji { font-size: 20px; }
    .pod-title { font-size: 13px; }
  }
</style>
