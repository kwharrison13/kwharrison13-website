---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPages = await getCollection('learning');
const published = allPages.filter(p => p.data.publish === true);

const byFormat = published.reduce((acc, p) => {
  const fmt = p.data.format || p.data.type || 'other';
  if (!acc[fmt]) acc[fmt] = [];
  acc[fmt].push(p);
  return acc;
}, {} as Record<string, typeof published>);

const formatOrder = ['frameworks', 'checklist', 'playbook', 'other'];
const sortedFormats = [
  ...formatOrder.filter(f => byFormat[f]),
  ...Object.keys(byFormat).filter(f => !formatOrder.includes(f)),
];

const formatLabels: Record<string, string> = {
  frameworks: 'Frameworks & Checklists',
  checklist: 'Checklists',
  playbook: 'Playbooks',
};
---

<BaseLayout title="Learning" currentPage="learning" description="Courses, frameworks, and ongoing education from Kyle Harrison.">
  <h1 class="page-title">Learning</h1>
  <p class="page-subtitle">Frameworks, checklists, and curated reference material.</p>

  {published.length === 0 ? (
    <div class="empty-state">
      <span class="empty-icon">∞</span>
      <p>No public learning pages yet — check back soon.</p>
    </div>
  ) : (
    sortedFormats.map(fmt => (
      <section class="format-section">
        <h2 class="format-heading">{formatLabels[fmt] || fmt}</h2>
        <ul class="page-list">
          {byFormat[fmt].map(p => (
            <li class="page-item">
              <a href={`/learning/${p.slug}`} class="page-link">
                <span class="page-title-text">{p.data.title}</span>
                {p.data.description && (
                  <span class="page-desc">{p.data.description}</span>
                )}
              </a>
              {p.data.tags && p.data.tags.length > 0 && (
                <div class="page-tags">
                  {p.data.tags.map(t => <span class="tag">{t}</span>)}
                </div>
              )}
            </li>
          ))}
        </ul>
      </section>
    ))
  )}
</BaseLayout>

<style>
  .page-subtitle {
    font-size: 16px;
    color: var(--text-secondary);
    margin: 0 0 40px;
  }

  .empty-state {
    text-align: center;
    padding: 80px 0;
    color: var(--text-tertiary);
  }
  .empty-icon {
    font-size: 48px;
    display: block;
    margin-bottom: 16px;
  }

  .format-section { margin-bottom: 48px; }

  .format-heading {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-tertiary);
    margin: 0 0 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }

  .page-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 12px;
  }

  .page-item { display: flex; flex-direction: column; gap: 6px; }

  .page-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    text-decoration: none;
  }
  .page-link:hover .page-title-text { color: var(--accent); }

  .page-title-text {
    font-size: 16px;
    font-weight: 600;
    color: var(--text);
    transition: color 0.15s;
  }

  .page-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .page-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .tag {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--text-tertiary);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1px 7px;
  }
</style>
